-- =========================
-- CONSULTATION TABLE
-- =========================

CREATE TABLE tbl_consultation (

    id BIGINT PRIMARY KEY
    GENERATED BY DEFAULT AS IDENTITY,

    appointment_id BIGINT NOT NULL
    REFERENCES tbl_appointment(appointment_id)
    ON DELETE CASCADE,

    consultation_details TEXT,

    consultation_fee INTEGER NOT NULL,

    payment_status VARCHAR(50)
    DEFAULT 'pending',

    consultation_status VARCHAR(50)
    DEFAULT 'inactive',

    created_at TIMESTAMP
    DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP
    DEFAULT CURRENT_TIMESTAMP
);



-- =========================
-- TASK TABLE
-- =========================

CREATE TABLE tbl_task (

    id BIGINT PRIMARY KEY
    GENERATED BY DEFAULT AS IDENTITY,

    appointment_id BIGINT NOT NULL
    REFERENCES tbl_appointment(appointment_id)
    ON DELETE CASCADE,

    task_title VARCHAR(255) NOT NULL,

    task_details TEXT NOT NULL,

    task_startdate DATE NOT NULL,

    task_enddate DATE NOT NULL,

    task_status INT NOT NULL DEFAULT 0,

    is_completed BOOLEAN DEFAULT FALSE,

    created_at TIMESTAMP
    DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP
    DEFAULT CURRENT_TIMESTAMP
);



-- =========================
-- TASK SUBMISSION TABLE
-- =========================

CREATE TABLE tbl_task_submission (

    id UUID PRIMARY KEY
    DEFAULT gen_random_uuid(),

    task_id BIGINT NOT NULL
    REFERENCES tbl_task(id)
    ON DELETE CASCADE,

    appointment_id BIGINT NOT NULL
    REFERENCES tbl_appointment(appointment_id)
    ON DELETE CASCADE,

    parent_id UUID NOT NULL
    REFERENCES tbl_parent(parent_id)
    ON DELETE CASCADE,

    submission_text TEXT NOT NULL,

    submission_file TEXT,

    status VARCHAR(50)
    NOT NULL DEFAULT 'pending',

    points INTEGER,

    submitted_at TIMESTAMP WITH TIME ZONE
    DEFAULT CURRENT_TIMESTAMP,

    created_at TIMESTAMP WITH TIME ZONE
    DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP WITH TIME ZONE
    DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE tbl_chat (

    chat_id BIGINT PRIMARY KEY
    GENERATED BY DEFAULT AS IDENTITY,

    from_parentid UUID
    REFERENCES tbl_parent(parent_id)
    ON DELETE CASCADE,

    to_parentid UUID
    REFERENCES tbl_parent(parent_id)
    ON DELETE CASCADE,

    from_psychologistid UUID
    REFERENCES tbl_psycologist(psycologist_id)
    ON DELETE CASCADE,

    to_psychologistid UUID
    REFERENCES tbl_psycologist(psycologist_id)
    ON DELETE CASCADE,

    appointment_id BIGINT
    REFERENCES tbl_appointment(appointment_id)
    ON DELETE CASCADE,

    chat_content TEXT,

    chat_file TEXT,

    chat_replyto BIGINT
    REFERENCES tbl_chat(chat_id)
    ON DELETE SET NULL,

    chat_isread BOOLEAN DEFAULT FALSE,

    created_at TIMESTAMP WITH TIME ZONE
    DEFAULT CURRENT_TIMESTAMP,

    updated_at TIMESTAMP WITH TIME ZONE
    DEFAULT CURRENT_TIMESTAMP
);
-- Enable Realtime
alter table public.tbl_chat replica identity full;
alter publication supabase_realtime add table tbl_chat;



CREATE TABLE tbl_rating (
    rating_id BIGSERIAL PRIMARY KEY,

    appointment_id BIGINT NOT NULL,
    psychologist_id UUID NOT NULL,

    rating INTEGER NOT NULL CHECK (rating >= 1 AND rating <= 5),

    review TEXT,

    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_rating_appointment
        FOREIGN KEY (appointment_id)
        REFERENCES tbl_appointment(appointment_id)
        ON DELETE CASCADE
);
